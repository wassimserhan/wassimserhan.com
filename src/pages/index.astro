---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const imageFiles = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/photos/*.{jpg,jpeg,webp,png}',
	{ eager: true }
);

const photos = Object.entries(imageFiles)
	.sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
	.map(([path, mod]) => ({
		src: mod.default,
		alt: path.split('/').pop()?.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ') ?? '',
	}));
---

<Layout>
	<main class="gallery">
		{
			photos.map((photo, i) => (
				<figure>
					<Image
						src={photo.src}
						alt={photo.alt}
						loading={i === 0 ? 'eager' : 'lazy'}
						widths={[800, 1400, 2400]}
						sizes="100vw"
					/>
				</figure>
			))
		}
	</main>
</Layout>

<style>
	.gallery {
  margin: 0;
  padding: 0;
}

figure:first-child {
  margin-top: 64px;
}

	figure {
  margin: 0;
  padding: 0;
  line-height: 0;
  height: calc(100vh - 64px);
  display: flex;
  align-items: center;
  justify-content: center;
}

	figure + figure {
  margin-top: 5px;
}

	img {
  width: 100%;
  height: 100%;
  object-fit: contain;  /* full image always visible, black bars if needed */
  display: block;
}
</style>
