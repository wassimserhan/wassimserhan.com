---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Wassim Serhan Photographs">
	<main class="contact">
		<div class="content">
			<h1>Contact</h1>
			<p class="subtitle">For inquiries, commissions, or just to say hello.</p>

			<form name="contact" method="POST" action="/success/" data-netlify="true" data-netlify-honeypot="bot-field" class="form">
				<input type="hidden" name="form-name" value="contact" />
				<p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

				<div class="field">
					<input type="text" name="name" id="name" placeholder="Name" required />
				</div>
				<div class="field">
					<input type="email" name="email" id="email" placeholder="Email" required />
				</div>
				<div class="field">
					<textarea name="message" id="message" rows="5" placeholder="Message" required></textarea>
				</div>
				<button type="submit">Send</button>
			</form>

			<div class="social">
				<a href="https://instagram.com/wassimserhan" target="_blank" rel="noopener noreferrer">Instagram</a>
			</div>
		</div>
	</main>
</Layout>

<style>
	.contact {
		padding-top: 64px;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.content {
		max-width: 480px;
		width: 100%;
		padding: 4rem 2rem;
		text-align: center;
	}

	h1 {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 1.05rem;
		font-weight: 400;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: #f0f0f0;
		margin: 0 0 1rem;
	}

	.subtitle {
		font-size: 0.8rem;
		line-height: 1.85;
		color: #555;
		margin: 0 0 2.5rem;
		letter-spacing: 0.05em;
	}

	.hidden {
		display: none;
	}

	.form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 3rem;
		text-align: left;
	}

	.field input,
	.field textarea {
		width: 100%;
		background: transparent;
		border: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
		padding: 0.75rem 0;
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.8rem;
		font-weight: 300;
		letter-spacing: 0.08em;
		color: #ccc;
		outline: none;
		transition: border-color 0.2s;
		resize: none;
	}

	.field input::placeholder,
	.field textarea::placeholder {
		color: #444;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-size: 0.68rem;
	}

	.field input:focus,
	.field textarea:focus {
		border-bottom-color: rgba(255, 255, 255, 0.4);
	}

	button[type='submit'] {
		align-self: flex-start;
		background: none;
		border: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.2);
		padding: 0.4rem 0;
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.68rem;
		font-weight: 400;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #888;
		cursor: pointer;
		transition: color 0.2s, border-color 0.2s;
		margin-top: 0.5rem;
	}

	button[type='submit']:hover {
		color: #f0f0f0;
		border-color: rgba(255, 255, 255, 0.6);
	}

	.social {
		display: flex;
		justify-content: center;
		gap: 2rem;
	}

	.social a {
		font-size: 0.68rem;
		font-weight: 400;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #444;
		text-decoration: none;
		transition: color 0.2s;
	}

	.social a:hover {
		color: #f0f0f0;
	}
</style>
