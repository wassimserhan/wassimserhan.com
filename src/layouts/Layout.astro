---
interface Props {
	title?: string;
}
const { title = 'Wassim Serhan' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Wassim Serhan — Photography portfolio" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Inter:wght@300;400&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header>
			<nav>
				<a href="/" class="logo">Wassim Serhan</a>
				<ul class="desktop-menu">
					<li><a href="/">Photographs</a></li>
					<li class="has-dropdown">
						<span class="projects-label">Projects</span>
						<ul class="dropdown">
							<div class="dropdown-inner">
								<li><a href="/projects/haiti">Haiti</a></li>
								<li><a href="/projects/tartan-day">Tartan Day</a></li>
								<li><a href="/projects/keep-this-far-apart">Keep This Far Apart</a></li>
							</div>
						</ul>
					</li>
					<li><a href="/about">About</a></li>
					<li><a href="/contact">Contact</a></li>
				</ul>
				<button class="hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
					<span></span>
					<span></span>
					<span></span>
				</button>
			</nav>
		</header>

		<div id="mobile-menu" role="dialog" aria-label="Navigation menu">
			<div class="mobile-header">
				<a href="/" class="mobile-logo">Wassim Serhan</a>
				<button class="mobile-close" aria-label="Close menu">
					<span></span>
					<span></span>
				</button>
			</div>
			<ul>
				<li><a href="/">Photographs</a></li>
				<li>
					<span class="projects-label">Projects</span>
					<ul class="mobile-sub">
						<li><a href="/projects/haiti">Haiti</a></li>
						<li><a href="/projects/tartan-day">Tartan Day</a></li>
						<li><a href="/projects/keep-this-far-apart">Keep This Far Apart</a></li>
					</ul>
				</li>
				<li><a href="/about">About</a></li>
				<li><a href="/contact">Contact</a></li>
			</ul>
		</div>
		<slot />
	</body>
</html>

<script>
	const btn = document.querySelector('.hamburger') as HTMLButtonElement;
	const closeBtn = document.querySelector('.mobile-close') as HTMLButtonElement;
	const menu = document.getElementById('mobile-menu');

	function openMenu() {
		btn.setAttribute('aria-expanded', 'true');
		menu?.classList.add('is-open');
		document.body.classList.add('menu-open');
	}

	function closeMenu() {
		btn.setAttribute('aria-expanded', 'false');
		menu?.classList.remove('is-open');
		document.body.classList.remove('menu-open');
	}

	btn?.addEventListener('click', () => {
		btn.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
	});

	closeBtn?.addEventListener('click', closeMenu);

	menu?.querySelectorAll('a').forEach(link => {
		link.addEventListener('click', closeMenu);
	});
</script>

<style>
	:global(*, *::before, *::after) {
		box-sizing: border-box;
	}

	:global(html) {
		margin: 0;
		padding: 0;
		background-color: #080808;
		color: #e0e0e0;
		scroll-behavior: smooth;
	}

	:global(body) {
		margin: 0;
		padding: 0;
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
		font-weight: 300;
	}

	:global(figure) {
		margin: 0;
		padding: 0;
		line-height: 0;
		height: calc(100dvh - 64px);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	:global(figure + figure) {
		margin-top: 5px;
	}

	:global(.gallery img) {
		width: 100%;
		height: 100%;
		object-fit: contain;
		display: block;
	}

	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		height: 64px;
		background: rgba(8, 8, 8, 0.82);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 100%;
		padding: 0 2.5rem;
	}

	.logo {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 1.375rem;
		font-weight: 400;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #f0f0f0;
		text-decoration: none;
		transition: color 0.2s;
	}

	.logo:hover {
		color: #ffffff;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		gap: 2.5rem;
	}

	ul a {
		font-size: 0.68rem;
		font-weight: 400;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #bbb;
		text-decoration: none;
		transition: color 0.2s;
	}

	ul a:hover {
		color: #f0f0f0;
	}

	.has-dropdown {
		position: relative;
	}

	.projects-label {
		font-size: 0.68rem;
		font-weight: 400;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #bbb;
		cursor: default;
		user-select: none;
	}

	.projects-label::after {
		content: ' ▾';
		font-size: 0.55rem;
		opacity: 0.6;
	}

	.dropdown {
		display: none;
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%);
		padding-top: 12px;
		background: transparent;
		min-width: 120px;
		flex-direction: column;
		gap: 0;
	}

	.dropdown-inner {
		background: rgba(12, 12, 12, 0.95);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		padding: 0.5rem 0;
	}

	.has-dropdown:hover .dropdown {
		display: flex;
	}

	.dropdown li {
		list-style: none;
	}

	.dropdown a {
		display: block;
		padding: 0.6rem 1.25rem;
		white-space: nowrap;
	}

	.dropdown a:hover {
		background: rgba(255, 255, 255, 0.05);
	}

	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
		z-index: 101;
	}

	.hamburger span {
		display: block;
		width: 22px;
		height: 1px;
		background: #bbb;
		transition: transform 0.25s, opacity 0.25s;
		transform-origin: center;
	}

	.hamburger[aria-expanded='true'] span:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}

	.hamburger[aria-expanded='true'] span:nth-child(2) {
		opacity: 0;
	}

	.hamburger[aria-expanded='true'] span:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}

	.mobile-header {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 1.25rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.mobile-logo {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 1.375rem;
		font-weight: 400;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #f0f0f0;
		text-decoration: none;
	}

	.mobile-close {
		position: static;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
		width: 28px;
		height: 28px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.mobile-close span {
		position: absolute;
		width: 22px;
		height: 1px;
		background: #bbb;
		display: block;
	}

	.mobile-close span:nth-child(1) {
		transform: rotate(45deg);
	}

	.mobile-close span:nth-child(2) {
		transform: rotate(-45deg);
	}

	#mobile-menu {
		display: none;
		position: fixed;
		inset: 0;
		background: #080808;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		z-index: 200;
	}

	#mobile-menu.is-open {
		display: flex;
	}

	#mobile-menu > ul {
		flex-direction: column;
		align-items: center;
		gap: 2.5rem;
	}

	#mobile-menu > ul > li {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		text-align: center;
	}

	#mobile-menu > ul > li > a,
	#mobile-menu .projects-label {
		font-size: 0.8rem;
		letter-spacing: 0.25em;
	}

	#mobile-menu .projects-label::after {
		display: none;
	}

	.mobile-sub {
		flex-direction: column;
		align-items: center;
		gap: 1rem !important;
	}

	.mobile-sub a {
		font-size: 0.65rem !important;
		color: #666 !important;
	}

	@media (max-width: 600px) {
		:global(figure) {
			height: auto;
		}

		nav {
			padding: 0 1.25rem;
		}

		.hamburger {
			display: flex;
		}

		.desktop-menu {
			display: none;
		}

		:global(body.menu-open) {
			overflow: hidden;
		}
	}
</style>
